  "tips": [
    {
      "id": "how-to-log",
      "title": "What you can log (and how)",
      "body": "Tell the logging chat in plain language and it updates data.json:\n• Room — name, color (blue/orange/green/purple/yellow/red/black), rarity, doors, gem/coin/key cost, dig spot, effect, variants.\n• Item — name, type (Resource/Key/Tool/Consumable/Document/Other), effect, where found, shop price.\n• Run — say “new run” to bump the counter; note the rank reached and the outcome.\n• Sighting — “in this run the Courtyard had 2 gems” records what a room held that run.\n• Puzzle — clues plus the full solution (stored here on purpose).\n• Note — any free-form observation.\n• Tip — entries like this one; they can include an image.",
      "tags": [
        "guide"
      ]
    },
    {
      "id": "example-with-image",
      "title": "Example: a tip with an image",
      "body": "Tips can include a picture — host it in this repo (e.g. an images/ folder) and reference it, or use any public image URL. Handy for floorplans, puzzle screenshots, or maps.",
      "image": "images/example.svg",
      "tags": [
        "example",
        "image"
      ]
    },
    {
      "id": "quick-examples",
      "title": "Quick examples — what to say to the logging chat",
      "body": "• “Log a room: Aquarium — green, Standard, 2 doors, has a dig spot.”\n• “Item: Compass — Tool, points toward the Antechamber.”\n• “New run.” (bumps the run counter)\n• “In run 2 the Courtyard had 2 gems and a key.” (records a sighting)\n• “Mark the Boiler Room solved — pull the lever twice.” (puzzle + solution)\n• “Tip: <text>” and optionally an image path.",
      "tags": [
        "example",
        "guide"
      ]
    },
    {
      "id": "tracking-runs",
      "title": "Tracking runs in the viewer",
      "body": "Rooms and Items are tables. The Runs column shows every run a thing has appeared in. Set the run number at the top with − / +, then click “+ run N” on a row to mark that it showed up this run. Those marks are saved in your browser (dashed/amber chips) until the logging chat records a real sighting in data.json (solid chips). The chip matching the current run is highlighted.",
      "tags": [
        "guide"
      ]
    }
  ]
}
